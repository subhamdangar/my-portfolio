# ===== PORTFOLIO ENVIRONMENT VARIABLES =====
# 
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Get your free API key from: https://openrouter.ai
# 1. Sign up at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys
# 3. Create a new key and paste it below
#
OPENROUTER_API_KEY=your_key_here

# ===== OPTIONAL: Change the AI model =====
# Default model is meta-llama/llama-4-maverick (free tier)
# You can change this to any model available on OpenRouter
# See all models at: https://openrouter.ai/models
# OPENROUTER_MODEL=meta-llama/llama-4-maverick
